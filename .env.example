PORT=3000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
JWT_SECRET=replace_with_a_random_32_character_secret
REDIS_URL=redis://127.0.0.1:6379
BOOKING_PAUSE_SECRET=replace_with_a_secure_admin_control_secret

GEMINI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

IMAGE_UPLOAD_PROVIDER=supabase_storage
SUPABASE_STORAGE_BUCKET=temple-assets

# Twilio (WhatsApp/SMS booking confirmations)
# For WhatsApp sandbox, From is usually: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# Set to 'whatsapp' to send WhatsApp, or 'sms' to send normal SMS
TWILIO_CHANNEL=whatsapp
